rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidPotholeReport(data) {
      return data.keys().hasAll(["userId", "encodedPath", "createdAt", "status", "severity"])
        && data.keys().size() >= 5 && data.keys().size() <= 25
        && data.userId is string && data.userId.size() > 0 && data.userId == request.auth.uid
        && data.encodedPath is string && data.encodedPath.size() <= 100000
        && data.status in ["reported", "confirmed", "fixed"]
        && data.severity in ["low", "medium", "high"]
        && (!("address" in data) || (data.address is string && data.address.size() <= 1000))
        && (!("notes" in data) || (data.notes is string && data.notes.size() <= 2000))
        && (!("imageUrl" in data) || (data.imageUrl is string && data.imageUrl.size() <= 800000))
        && (!("userName" in data) || (data.userName is string && data.userName.size() <= 100))
        && (!("district" in data) || (data.district is string && data.district.size() <= 200))
        && (!("upvoterIds" in data) || (data.upvoterIds is list && data.upvoterIds.size() <= 10000))
        && (!("downvoterIds" in data) || (data.downvoterIds is list && data.downvoterIds.size() <= 10000))
        && (!("acName" in data) || (data.acName is string && data.acName.size() <= 200))
        && (!("acNo" in data) || data.acNo is int)
        && (!("pcName" in data) || (data.pcName is string && data.pcName.size() <= 200))
        && (!("lsgd" in data) || (data.lsgd is string && data.lsgd.size() <= 200))
        && (!("lsgdType" in data) || (data.lsgdType is string && data.lsgdType.size() <= 100))
        && (!("lsgdLabel" in data) || (data.lsgdLabel is string && data.lsgdLabel.size() <= 200))
        && (!("highwayTag" in data) || (data.highwayTag is string && data.highwayTag.size() <= 100))
        && (!("roadAuthority" in data) || (data.roadAuthority is string && data.roadAuthority.size() <= 50))
        && (!("wardNo" in data) || data.wardNo is int || (data.wardNo is string && data.wardNo.size() <= 20))
        && (!("wardName" in data) || (data.wardName is string && data.wardName.size() <= 200))
        && (!("distanceM" in data) || (data.distanceM is int && data.distanceM > 0 && data.distanceM <= 1000))
        && (!("secLsgCode" in data) || (data.secLsgCode is string && data.secLsgCode.size() <= 20));
    }

    function isSafeRoadEnrich() {
      let keys = incoming().diff(existing()).affectedKeys();
      return keys.hasOnly(['highwayTag', 'roadAuthority'])
        && !('highwayTag' in existing())
        && !('roadAuthority' in existing())
        && incoming().highwayTag is string && incoming().highwayTag.size() <= 100
        && incoming().roadAuthority is string && incoming().roadAuthority.size() <= 50;
    }

    function isSafeWardEnrich() {
      let keys = incoming().diff(existing()).affectedKeys();
      return keys.hasOnly(['wardNo', 'wardName'])
        && existing().get('wardNo', null) == null
        && (incoming().get('wardNo', null) is int || (incoming().get('wardNo', null) is string && incoming().wardNo.size() <= 20))
        && (!('wardName' in keys) || (incoming().wardName is string && incoming().wardName.size() <= 200));
    }

    function isSafeVote() {
      let keys = incoming().diff(existing()).affectedKeys();
      let onlyVotes = keys.hasOnly(['upvoterIds', 'downvoterIds']);
      
      let oldUp = existing().get('upvoterIds', []);
      let newUp = incoming().get('upvoterIds', []);
      let validUp = !('upvoterIds' in keys) || (
        newUp is list && newUp.size() <= 10000 && (
          (newUp.size() == oldUp.size() + 1 && request.auth.uid in newUp && !(request.auth.uid in oldUp)) ||
          (newUp.size() == oldUp.size() - 1 && !(request.auth.uid in newUp) && request.auth.uid in oldUp)
        )
      );

      let oldDown = existing().get('downvoterIds', []);
      let newDown = incoming().get('downvoterIds', []);
      let validDown = !('downvoterIds' in keys) || (
        newDown is list && newDown.size() <= 10000 && (
          (newDown.size() == oldDown.size() + 1 && request.auth.uid in newDown && !(request.auth.uid in oldDown)) ||
          (newDown.size() == oldDown.size() - 1 && !(request.auth.uid in newDown) && request.auth.uid in oldDown)
        )
      );

      return onlyVotes && validUp && validDown;
    }

    match /potholes/{potholeId} {
      allow read: if true; // Publicly viewable on the map
      allow create: if isSignedIn() && isValidId(potholeId) && isValidPotholeReport(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
        isSafeVote() ||
        isSafeRoadEnrich() ||
        isSafeWardEnrich() ||
        (isValidPotholeReport(incoming()) && incoming().createdAt == existing().createdAt && existing().userId == incoming().userId && existing().userId == request.auth.uid)
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
